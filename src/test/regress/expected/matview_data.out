  mvname  | datastatus 
----------+------------
 mv_join2 | i
(1 row)

abort;
-- Cross join (FROM t1, t2 with no WHERE): verify registration
create materialized view mv_cross_join as
  select jt1.id as id1, jt2.id as id2 from jt1, jt2;
